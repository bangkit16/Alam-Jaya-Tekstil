// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  nama         String
  username     String   @unique
  password     String
  noHandphone  String   @unique

  role         Role

  sessions     Session[]

  penanggungJawabBox Box[] @relation("PenanggungJawabBox")
  penerimaBox        Box[] @relation("PenerimaBox")

  penjahitProses     ProsesStokPotong[] @relation("Penjahit")
  kurirProses     ProsesStokPotong[] @relation("KurirKePenjahit")
  kurirQCProses   ProsesStokPotong[] @relation("KurirKeQC")


  pemotongan   StokPotongPemotong[]
  pengecekan   StokPotongPengecek[]
  pengecekanQC QCPengecek[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  createdAt    DateTime @default(now())

}

model Kategori {
  id           String   @id @default(uuid())
  namaKategori String
  slug         String   @unique
  kodeKategori String

  permintaan   Permintaan[]
}

model Permintaan {
  id                  String   @id @default(uuid())
  kategoriId          String
  namaBarang          String
  ukuran              UkuranProduk
  jumlahMinta         Int
  jenisPermintaan     JenisPermintaan
  isUrgent            Boolean  @default(false)
  tanggalMasuk        DateTime @default(now())
  
  status              StatusPermintaan

  kategori            Kategori @relation(fields: [kategoriId], references: [id])

  stokPotong          StokPotong?
  box                 Box[]

  logs                PermintaanLog[]
}

model PermintaanLog {
  id            String   @id @default(uuid())
  permintaanId  String
  status        StatusPermintaan
  keterangan    String?
  createdAt     DateTime @default(now())

  permintaan    Permintaan @relation(fields: [permintaanId], references: [id])
}

model StokPotong {
  id                 String   @id @default(uuid())
  permintaanId       String   @unique

  kodeKain           String
  kodeStokPotongan   String?

  tanggalMasuk       DateTime @default(now())
  tanggalCek         DateTime?
  tanggalSelesai     DateTime?

  jumlahHasil        Int?
  jumlahLolos        Int?
  jumlahReject       Int?

  notes              String?

  status             StatusStokPotong

  permintaan         Permintaan @relation(fields: [permintaanId], references: [id])

  proses             ProsesStokPotong?
  qc                 QCStokPotong?

  pemotong           StokPotongPemotong[]
  pengecek           StokPotongPengecek[]
}

model StokPotongPemotong {
  id            String @id @default(uuid())
  stokPotongId  String
  userId        String

  stokPotong    StokPotong @relation(fields: [stokPotongId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

model StokPotongPengecek {
  id            String @id @default(uuid())
  stokPotongId  String
  userId        String

  stokPotong    StokPotong @relation(fields: [stokPotongId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

model QCPengecek {
  id            String @id @default(uuid())
  qcId  String
  userId        String

  qc            QCStokPotong @relation(fields: [qcId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

model ProsesStokPotong {
  id                  String   @id @default(uuid())
  stokPotongId        String   @unique

  penjahitId          String?
  kurirId             String?
  kurirQCId           String? // Kurir ke QC

  tanggalBerangkat    DateTime?
  tanggalSampai       DateTime?
  tanggalMulaiJahit   DateTime?
  tanggalSelesaiJahit DateTime?
  tanggalBerangkatKeQC    DateTime?
  tanggalSampaiKeQC       DateTime?

  jumlahSelesai       Int?
  notes               String?

  status              StatusProses

  stokPotong          StokPotong @relation(fields: [stokPotongId], references: [id])

  penjahit            User? @relation("Penjahit", fields: [penjahitId], references: [id])
  kurir               User? @relation("KurirKePenjahit", fields: [kurirId], references: [id])
  kurirQC             User? @relation("KurirKeQC", fields: [kurirQCId], references: [id])
}

model QCStokPotong {
  id                 String   @id @default(uuid())
  stokPotongId       String   @unique
  boxId              String?


  jumlahLolos        Int?
  jumlahReject       Int?
  jumlahKotor        Int?
  jumlahTurunSize    Int?
  jumlahPermak       Int?

  tanggalMulaiQC          DateTime?
  tanggalSelesaiQC          DateTime?
  notes              String?

  status             StatusQC

pengecek           QCPengecek[]

  stokPotong         StokPotong @relation(fields: [stokPotongId], references: [id])
  box                Box?       @relation(fields: [boxId], references: [id])
}

model Box {
  id                      String   @id @default(uuid())
  permintaanId            String?

  kodeBox                 String    @unique
  namaBox                 String

  penanggungJawabId       String?
  penerimaId              String?

  tanggalMasuk            DateTime?
  tanggalMasukGudang      DateTime?

  status                  StatusBox

  permintaan              Permintaan? @relation(fields: [permintaanId], references: [id])
  qc                      QCStokPotong[]

  penanggungJawab         User? @relation("PenanggungJawabBox", fields: [penanggungJawabId], references: [id])
  penerima                User? @relation("PenerimaBox", fields: [penerimaId], references: [id])
}

enum Role {
  POTONG
  STOK_POTONG
  KURIR
  JAHIT
  QC
  STOK_GUDANG
  SUPERADMIN
  RESI
  PRINT
}

enum JenisPermintaan {
  RESI
  BORDIR
  GUDANG
}

enum StatusPermintaan {
  MENUNGGU_GUDANG
  MENUNGGU_POTONG
  PROSES_POTONG
  MENUNGGU_STOK_POTONG
  PROSES_STOK_POTONG
  MENUNGGU_KURIR
  PROSES_KURIR
  MENUNGGU_JAHIT
  PROSES_JAHIT
  JEDA_JAHIT
  MENUNGGU_QC
  PROSES_QC
  MASUK_BOX
  ACC_GUDANG
}

enum StatusStokPotong {
  MENUNGGU
  PROSES
  SELESAI
  KIRIM
}

enum StatusProses {
  MENUNGGU_PENGIRIMAN
  PROSES_PENGIRIMAN
  SELESAI_PENGIRIMAN
  DIKERJAKAN
  JEDA
  SELESAI_JAHIT
  MENUNGGU_PENGIRIMAN_KE_QC
  PROSES_PENGIRIMAN_KE_QC
  SELESAI_PENGIRIMAN_KE_QC
}

enum StatusQC {
  MENUNGGU
  PROSES
  MASUK_BOX
  SELESAI
}

enum StatusBox {
  MENUNGGU
  ACC
  KIRIM
}

enum UkuranProduk {
  XL
  XXL
  L
  M
}
